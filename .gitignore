# =============================================================================
# Sadhana-Vak .gitignore
# =============================================================================

# ── AI Models (large binary files — store separately) ─────────────────────────
backend/models/
*.gguf
*.onnx
*.bin
*.pt
*.pth

# ── Python ────────────────────────────────────────────────────────────────────
backend/.venv/
**/__pycache__/
**/*.py[cod]
**/*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
*.cover

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.secret

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing ───────────────────────────────────────────────────────────────────
.hypothesis/
