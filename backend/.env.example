# =============================================================================
# Sadhana-Vak Backend — Environment Configuration
# Copy this file to .env and fill in values for your machine.
# =============================================================================

# ── LLM via Ollama (default) ──────────────────────────────────────────────────
# Qwen3-14B is the approved model. Run: ollama pull qwen3:14b
# See docs/architecture/06-tech-stack.md for license details.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:14b

# ── Model Paths (all under backend/models/) ───────────────────────────────────
# Moonshine-Small for STT (Apache 2.0)
#   Download: https://huggingface.co/useful-transformers/moonshine-small-onnx
STT_MODEL_DIR=./models/moonshine-small

# Sanskrit VITS/Piper voice for TTS (MIT)
#   Download or fine-tune from IIT-Madras dataset via Piper's training pipeline
TTS_MODEL_PATH=./models/vits-sanskrit.onnx

# Silero VAD ONNX (MIT) — used by backend VAD pre-processing hook
#   Download: https://github.com/snakers4/silero-vad/raw/master/src/silero_vad/data/silero_vad.onnx
VAD_MODEL_PATH=./models/silero_vad.onnx

# Qwen3-14B GGUF (Apache 2.0) — only needed if using llama-cpp-python directly
# (not needed when using Ollama)
LLM_MODEL_PATH=./models/qwen3-14b-instruct.Q4_K_M.gguf

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed Next.js dev server origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
